# Copy to .env — everything works with all of these left empty (mock provider mode).

# Free-tier provider keys (https://console.groq.com, https://aistudio.google.com)
GROQ_API_KEY=
GEMINI_API_KEY=

# Failover order. Keep "mock" last as a keyless fallback; set to just "mock"
# for zero-cost load testing.
PROVIDERS_ORDER=groq,gemini,mock

# "hash" = local zero-dep embedding (offline). "gemini" = real semantic
# embeddings via the free Gemini embedding API (requires GEMINI_API_KEY,
# also set EMBEDDING_DIMENSION=768).
EMBEDDING_PROVIDER=hash
EMBEDDING_DIMENSION=384

# Data-justified via scripts/threshold_eval.py: 0.66 for hash embeddings
# (62% hit / 0% false-hit). Use ~0.85+ with gemini embeddings.
SEMANTIC_THRESHOLD=0.66
ORG_BUDGET_USD=25
ADMIN_KEY=admin-secret
MOCK_LATENCY_MS=200
MAX_CONCURRENT=64
